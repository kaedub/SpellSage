// SpellSage Prisma 7 Schema
// Updated for Prisma 7 conventions and best practices

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model OracleCard {
  id               String   @id @db.Text
  oracleId         String   @unique @map("oracle_id")
  name             String
  set              String
  setId            String   @map("set_id")
  collectorNum     String   @map("collector_num")
  typeLine         String   @map("type_line")
  supertypes       String[]
  types            String[]
  subtypes         String[]
  rarity           String?
  isLegendary      Boolean  @map("is_legendary")
  colors           String[]
  colorIdentity    String[] @map("color_identity")
  manaCost         String?  @map("mana_cost")
  cmc              Float?
  oracleText       String?  @map("oracle_text")
  layout           String
  faces            Json?
  power            String?
  toughness        String?
  price            String?
  numericPower     Int?     @map("numeric_power")
  numericToughness Int?     @map("numeric_toughness")
  keywordsCi       String[] @default([]) @map("keywords_ci")
  keywords         String[]
  producedMana     String[] @map("produced_mana")
  gameChanger      Boolean  @map("game_changer")
  scryfallUri      String   @map("scryfall_uri")
  imageUri         String   @map("image_uri")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  printings           CardPrinting[]
  tags                OracleCardTag[]               @relation("OracleCardTags")
  collectionPrintings CollectionCardPrinting[]      @relation("OracleCardCollectionPrintings")
  taggingCompletions  OracleCardTaggingCompletion[] @relation("OracleCardTaggingCompletions")

  @@index([name])
  @@index([set])
  @@index([setId])
  @@index([typeLine])
  @@index([isLegendary])
  @@index([gameChanger])
  @@index([cmc])
  @@index([rarity])
  @@index([price])
  @@index([colors], type: Gin)
  @@index([colorIdentity], type: Gin)
  @@index([types], type: Gin)
  @@index([subtypes], type: Gin)
  @@index([supertypes], type: Gin)
  @@index([keywords], type: Gin)
  @@index([producedMana], type: Gin)
}

model CardPrinting {
  id               String   @id @db.Text
  oracleId         String   @map("oracle_id")
  name             String
  set              String
  setId            String   @map("set_id")
  collectorNum     String   @map("collector_num")
  typeLine         String   @map("type_line")
  supertypes       String[]
  types            String[]
  subtypes         String[]
  isLegendary      Boolean  @map("is_legendary")
  colors           String[]
  colorIdentity    String[] @map("color_identity")
  manaCost         String?  @map("mana_cost")
  cmc              Float?
  oracleText       String?  @map("oracle_text")
  layout           String
  faces            Json?
  power            String?
  toughness        String?
  rarity           String?
  price            String?
  numericPower     Int?     @map("numeric_power")
  numericToughness Int?     @map("numeric_toughness")
  keywordsCi       String[] @default([]) @map("keywords_ci")
  keywords         String[]
  producedMana     String[] @map("produced_mana")
  gameChanger      Boolean  @map("game_changer")
  scryfallUri      String   @map("scryfall_uri")
  imageUri         String   @map("image_uri")
  rawJson          Json     @map("raw_json")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  oracleCard      OracleCard               @relation(fields: [oracleId], references: [oracleId])
  collectionCards CollectionCardPrinting[] @relation("CardCollectionCards")

  @@index([name])
  @@index([set])
  @@index([setId])
  @@index([typeLine])
  @@index([isLegendary])
  @@index([gameChanger])
  @@index([cmc])
  @@index([oracleId])
  @@index([rarity])
  @@index([price])
  @@index([colors], type: Gin)
  @@index([colorIdentity], type: Gin)
  @@index([types], type: Gin)
  @@index([subtypes], type: Gin)
  @@index([keywords], type: Gin)
  @@index([producedMana], type: Gin)
}

model Collection {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cards CollectionCardPrinting[] @relation("CollectionCards")

  @@unique([userId, name])
  @@index([userId])
}

model CollectionCardPrinting {
  id           Int      @id @default(autoincrement())
  collectionId Int      @map("collection_id")
  printId      String   @map("card_id")
  oracleId     String   @map("oracle_id")
  quantity     Int
  foil         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  collection Collection   @relation("CollectionCards", fields: [collectionId], references: [id], onDelete: Cascade)
  card       CardPrinting @relation("CardCollectionCards", fields: [printId], references: [id])
  oracleCard OracleCard   @relation("OracleCardCollectionPrintings", fields: [oracleId], references: [oracleId])

  @@unique([collectionId, printId, foil])
  @@index([collectionId])
  @@index([printId])
}

model TagGroup {
  slug        String   @id
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tags Tag[] @relation("TagGroupTags")
}

model Tag {
  slug        String   @id
  groupSlug   String   @map("group_slug")
  definition  String
  mustHave    String[] @map("must_have")
  mustNotHave String[] @map("must_not_have")
  edgeRule    String?  @map("edge_rule")
  priority    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group       TagGroup        @relation("TagGroupTags", fields: [groupSlug], references: [slug])
  oracleCards OracleCardTag[] @relation("TagOracleCardTags")

  @@index([groupSlug])
}

model OracleCardTag {
  id        Int      @id @default(autoincrement())
  oracleId  String   @map("oracle_id")
  tagSlug   String   @map("tag_slug")
  source    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  oracleCard OracleCard @relation("OracleCardTags", fields: [oracleId], references: [oracleId])
  tag        Tag        @relation("TagOracleCardTags", fields: [tagSlug], references: [slug])

  @@unique([oracleId, tagSlug, source])
  @@index([oracleId])
  @@index([tagSlug])
}

/// Marks that the tagging pipeline finished for (cardId, source) with zero tags saved.
/// Cards with one or more CardTag rows for that source are considered done without this row.
model OracleCardTaggingCompletion {
  oracleId    String   @map("oracle_id")
  source      String
  completedAt DateTime @default(now()) @map("completed_at")

  oracleCard OracleCard @relation("OracleCardTaggingCompletions", fields: [oracleId], references: [oracleId])

  @@id([oracleId, source])
  @@index([source])
}

model Keyword {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  slug              String   @unique
  type              String
  rulesTextTemplate String   @map("rules_text_template")
  parameterized     Boolean
  parameterName     String?  @map("parameter_name")
  mechanicSummary   String?  @map("mechanic_summary")
  defaultTags       String[] @map("default_tags")
  tagNotes          String[] @map("tag_notes")
  example           String?
  setScope          String[] @map("set_scope")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([type])
}

model ScryfallSyncRun {
  id             Int       @id @default(autoincrement())
  startedAt      DateTime  @map("started_at")
  completedAt    DateTime? @map("completed_at")
  status         String
  cardsProcessed Int       @map("cards_processed")
  errorMessage   String?   @map("error_message")
}
