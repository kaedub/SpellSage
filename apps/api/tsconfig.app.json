{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "module": "nodenext",
    "types": ["node"],
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../../libs/ai/**/*.ts",
    "../../libs/platform/**/*.ts",
    "../../libs/shared/**/*.ts"
  ],
  "exclude": [],
  "references": [
    {
      "path": "../../libs/shared/tsconfig.lib.json"
    },
    {
      "path": "../../libs/platform/tsconfig.lib.json"
    }
  ]
}
